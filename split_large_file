import os
import time


def split_large_file(input_filepath, chunk_size_mb=500):
    # Added extra guard clause check for safety
    if input_filepath is None:
        print("Error: Received 'None' instead of a valid file path string.")
        return ""

    if not os.path.isfile(input_filepath):
        print(f"File not found: '{input_filepath}'. Please check the path.")
        return ""  # Returns empty string if file doesn't exist

    created_files = []  # Initialize the list to track all generated file paths

    # 1 MB in characters (approximate for standard ASCII/UTF-8)
    max_chars_per_file = chunk_size_mb * 1024 * 1024

    # Setup paths
    base_dir = os.path.dirname(input_filepath)
    base_name, ext = os.path.splitext(os.path.basename(input_filepath))

    # Create the new folder using the current epoch timestamp
    epoch_folder_name = str(int(time.time()))
    output_dir = os.path.join(base_dir, epoch_folder_name)
    os.makedirs(output_dir, exist_ok=True)

    file_number = 1
    current_chars_written = 0

    # Route the output files to the new epoch directory
    out_file_path = os.path.join(output_dir, f"{base_name}_part{file_number}{ext}")
    f_out = open(out_file_path, 'w', encoding='utf-8')

    # Read in 10 MB memory-safe chunks
    read_chunk_size = 10 * 1024 * 1024

    print(f"\nSplitting into {chunk_size_mb}MB chunks inside folder '{epoch_folder_name}'. This may take a minute...")

    try:
        with open(input_filepath, 'r', encoding='utf-8') as f_in:
            while True:
                chunk = f_in.read(read_chunk_size)
                if not chunk:
                    break  # End of file

                f_out.write(chunk)
                current_chars_written += len(chunk)

                # When the target size is reached, create the next file
                if current_chars_written >= max_chars_per_file:
                    f_out.close()
                    print(f"Saved: {out_file_path}")
                    created_files.append(out_file_path)  # Capture completed part file

                    file_number += 1
                    current_chars_written = 0
                    out_file_path = os.path.join(output_dir, f"{base_name}_part{file_number}{ext}")
                    f_out = open(out_file_path, 'w', encoding='utf-8')
    finally:
        # Ensure the final file is safely closed
        if not f_out.closed:
            f_out.close()
            # If the last file is completely empty, delete it
            if current_chars_written > 0:
                print(f"Saved: {out_file_path}")
                created_files.append(out_file_path)  # Capture the final part file
            else:
                os.remove(out_file_path)

    print(f"\nSplitting complete! Your files are located in:\n{output_dir}")
    return output_dir  # Return the directory path holding the split files


if __name__ == "__main__":
    path = input("Enter the path to the massive text file: ").strip().replace('"', '').replace("'", "")

    try:
        size_input = input("Enter target size per file in MB (default 500): ").strip()
        size = int(size_input) if size_input else 500
    except ValueError:
        print("Invalid input. Defaulting to 500 MB.")
        size = 500

    # Capturing the returned list if you run this script directly
    resulting_files = split_large_file(path, size)
